# --- Passerelle SMSGate ---
SMS_GATEWAY_URL=http://127.0.0.1:8080/message
SMS_GATEWAY_USER=your_username
SMS_GATEWAY_PASSWORD=your_password
SMS_GATEWAY_WEBHOOK_URL=http://127.0.0.1:5000/webhook

# --- Serveur Webhook ---
WEBHOOK_PORT=5000

# --- SMTP (Email sortant) ---
ENABLE_EMAIL=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Groupe SMS
